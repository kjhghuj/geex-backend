# GEEX Medusa backend environment template.
# Copy this file to .env for local development or configure the same keys in your host.
# Never commit real production secrets.

# Public URLs and CORS
MEDUSA_BACKEND_URL=http://localhost:9030
FRONTEND_URL=http://localhost:3030
STOREFRONT_URL=http://localhost:3030
STORE_CORS=http://localhost:3030
ADMIN_CORS=http://localhost:9030
AUTH_CORS=http://localhost:3030,http://localhost:9030

# Infrastructure
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medusa_geex
REDIS_URL=redis://localhost:6379
DB_NAME=medusa_geex

# Security
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_strong_random_value
COOKIE_SECRET=replace_with_strong_random_value

# Transactional email
RESEND_API_KEY=replace_with_resend_api_key
RESEND_FROM_EMAIL=GEEX <noreply@geexfans.com>

# Stripe payments
STRIPE_API_KEY=replace_with_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=replace_with_stripe_publishable_key

# Marketing integrations
KLAVIYO_PRIVATE_KEY=
KLAVIYO_LIST_ID=

# Cloudflare Turnstile
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret_key

# Cloudflare R2 / S3-compatible product assets
S3_FILE_URL=https://assets.geexfans.com
S3_ACCESS_KEY_ID=replace_with_r2_access_key_id
S3_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key
S3_BUCKET=geex-assets
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
